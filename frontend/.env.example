# ─────────────────────────────────────────────────────────────
# FMS Frontend — Environment Variables
# Copy this file to `.env` and fill in your own values.
# All NEXT_PUBLIC_* vars are exposed to the browser at build time.
# `.env` is gitignored — never commit real keys.
# ─────────────────────────────────────────────────────────────

# App URLs
NEXT_PUBLIC_URL=http://localhost:3000
# Base URL of the FMS backend API (the Cloudflare Worker, note the /api suffix)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8787/api

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Web Push (must match VAPID_PUBLIC_KEY in the backend)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<your-vapid-public-key>

# Cron auth token (must match CRON_SECRET in the backend)
NEXT_PUBLIC_CRON_SECRET=<random-hex-string>

# ── Optional integrations (leave blank to disable) ──
# Sentry error monitoring (empty = disabled)
NEXT_PUBLIC_SENTRY_DSN=
# Mixpanel product analytics (empty = disabled)
NEXT_PUBLIC_MIXPANEL_TOKEN=
# Microsoft Clarity session analytics (empty = disabled)
NEXT_PUBLIC_CLARITY_PROJECT_ID=
